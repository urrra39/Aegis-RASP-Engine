# Aegis RASP Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials.

# Dashboard authentication (required for admin endpoints)
AEGIS_ADMIN_TOKEN=change-me-to-a-strong-random-token

# Logging level: debug | info | warn | error
AEGIS_LOG_LEVEL=info

# Egress firewall: comma-separated allowed destination hosts
AEGIS_ALLOWED_EGRESS_HOSTS=api.example.com,cdn.example.com

# CORS: comma-separated allowed origins (use specific origins, never *)
AEGIS_CORS_ALLOWED_ORIGINS=https://app.example.com

# Enable/disable individual protection modules
AEGIS_ENABLE_SQLI_PROTECTION=true
AEGIS_ENABLE_RCE_PROTECTION=true
AEGIS_ENABLE_EGRESS_FIREWALL=true
